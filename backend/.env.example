# Server Configuration
NODE_ENV=production
PORT=5000

# MongoDB Configuration
# For local: mongodb://localhost:27017/skillverse
# For production: mongodb+srv://username:password@cluster.mongodb.net/skillverse?appName=Cluster
MONGO_URI=mongodb+srv://Haseeb:haseeb123@cluster0.eg6vwrs.mongodb.net/skillverse?appName=Cluster0

# JWT Configuration (use a strong random string for production)
JWT_SECRET=skillsverse_secret_key_12345

# Stripe Configuration (use test keys for development, live keys for production)
# Get these from your Stripe Dashboard: https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_your_secret_key_here
STRIPE_PUBLISHABLE_KEY=pk_test_your_publishable_key_here

# Stripe Connect — connected account ID (acct_...) for worker payouts
# Create a test/live Express connected account in Stripe Dashboard → Connect
STRIPE_CONNECT_DESTINATION_ACCOUNT=acct_xxxxxxxx

# Escrow: hold duration before worker payout (default 1 day)
ESCROW_HOLD_DAYS=1
# Optional: override hold for quick testing (e.g. 2 = release after 2 minutes)
# ESCROW_HOLD_MINUTES=2

# How often the server checks for due releases (default 3600000 = 1 hour)
ESCROW_CHECK_INTERVAL_MS=3600000

# CORS Configuration (for production, specify your frontend domain)
CORS_ORIGIN=*

# File Upload Configuration
# Note: Render's filesystem is ephemeral. For production file persistence,
# consider using cloud storage like AWS S3, Cloudinary, or similar services.
# Currently using local uploads folder which will reset on redeploy.
